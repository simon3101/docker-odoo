<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista del wizard de asignación rápida de etiquetas -->
    <record id="view_stock_product_tag_wizard_form" model="ir.ui.view">
        <field name="name">stock.product.tag.wizard.form</field>
        <field name="model">stock.product.tag.wizard</field>
        <field name="arch" type="xml">
            <form string="Asignar Etiquetas de Almacenamiento">
                <sheet>
                    <group>
                        <field name="product_id" readonly="1"/>
                        <field name="storage_tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color', 'no_create_edit': False}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" type="object"
                            string="Aplicar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

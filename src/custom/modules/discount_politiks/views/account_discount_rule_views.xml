<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario de regla de descuento -->
    <record id="view_account_discount_rule_form" model="ir.ui.view">
        <field name="name">account.discount.rule.form</field>
        <field name="model">account.discount.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Descuento">
                <sheet>
                    <group>
                        <field name="customer_type"/>
                        <field name="discount"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista lista de reglas de descuento -->
    <record id="view_account_discount_rule_list" model="ir.ui.view">
        <field name="name">account.discount.rule.list</field>
        <field name="model">account.discount.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de Descuento" editable="bottom">
                <field name="customer_type"/>
                <field name="discount"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Acción para gestionar reglas de descuento -->
    <record id="action_account_discount_rules" model="ir.actions.act_window">
        <field name="name">Reglas de Descuento</field>
        <field name="res_model">account.discount.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú en Contabilidad → Configuración -->
    <menuitem
        id="menu_account_discount_rules"
        name="Reglas de Descuento"
        parent="account.menu_finance_configuration"
        action="action_account_discount_rules"
        sequence="50"/>

</odoo>

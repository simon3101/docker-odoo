<?xml version="1.0" encoding="utf-8"?>
<odoo>

    

    <!-- Acción para ver las estructuras salariales de beneficios -->
    <record id="action_hr_benefit_structures" model="ir.actions.act_window">
        <field name="name">Estructuras de Beneficios</field>
        <field name="res_model">hr.payroll.structure</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type_id.name', 'in', ['Tiempo Completo', 'Medio Tiempo', 'Temporal'])]</field>
    </record>

    <!-- Acción para ver las reglas salariales de beneficios -->
    <record id="action_hr_benefit_rules" model="ir.actions.act_window">
        <field name="name">Reglas de Beneficios</field>
        <field name="res_model">hr.salary.rule</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('category_id.code', '=', 'BEN')]</field>
        <field name="context">{'default_category_id': False}</field>
    </record>
    
    <!-- Menú en Nómina → Configuración -->
    <menuitem
        id="menu_hr_benefit_rules"
        name="Reglas de Beneficios"
        parent="hr_payroll.menu_hr_salary_configuration"
        action="action_hr_benefit_rules"
        sequence="50"/>

    <menuitem
        id="menu_hr_benefit_structures"
        name="Estructuras de Beneficios"
        parent="hr_payroll.menu_hr_salary_configuration"
        action="action_hr_benefit_structures"
        sequence="51"/>

</odoo>

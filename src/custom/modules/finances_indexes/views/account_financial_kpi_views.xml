<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Vista formulario para crear y editar KPIs individualmente.
        Muestra todos los campos configurables: nombre, fórmula predefinida,
        umbrales de advertencia y crítico, y estado activo.
        No muestra value ni status porque son campos computados en tiempo real
        y no tienen sentido fuera del contexto del dashboard.
    -->
    <record id="view_account_financial_kpi_form" model="ir.ui.view">
        <field name="name">account.financial.kpi.form</field>
        <field name="model">account.financial.kpi</field>
        <field name="arch" type="xml">
            <form string="Indicador Financiero">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="formula"/>
                        <field name="threshold_warning"/>
                        <field name="threshold_critical"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--
        Vista lista editable (editable="bottom") que permite crear y modificar
        múltiples KPIs directamente desde la lista sin abrir el formulario.
        Útil para configuración rápida de umbrales en masa.
    -->
    <record id="view_account_financial_kpi_list" model="ir.ui.view">
        <field name="name">account.financial.kpi.list</field>
        <field name="model">account.financial.kpi</field>
        <field name="arch" type="xml">
            <list string="Indicadores Financieros" editable="bottom">
                <field name="name"/>
                <field name="formula"/>
                <field name="threshold_warning"/>
                <field name="threshold_critical"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!--
        Acción de ventana para gestionar la configuración de KPIs.
        Accesible desde el menú Contabilidad → Configuración → Indicadores Financieros.
        Vista por defecto es lista para facilitar la gestión de múltiples KPIs.
    -->
    <record id="action_account_financial_kpis" model="ir.actions.act_window">
        <field name="name">Indicadores Financieros</field>
        <field name="res_model">account.financial.kpi</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--
        Menú de configuración dentro de Contabilidad → Configuración.
        sequence=60 lo ubica después de las entradas estándar de contabilidad
        pero antes del final del menú de configuración.
    -->
    <menuitem
        id="menu_account_financial_kpis"
        name="Indicadores Financieros"
        parent="account.menu_finance_configuration"
        action="action_account_financial_kpis"
        sequence="60"/>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista formulario de KPI -->
    <record id="view_account_financial_kpi_form" model="ir.ui.view">
        <field name="name">account.financial.kpi.form</field>
        <field name="model">account.financial.kpi</field>
        <field name="arch" type="xml">
            <form string="Indicador Financiero">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="formula"/>
                        <field name="threshold_warning"/>
                        <field name="threshold_critical"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista lista de KPIs -->
    <record id="view_account_financial_kpi_list" model="ir.ui.view">
        <field name="name">account.financial.kpi.list</field>
        <field name="model">account.financial.kpi</field>
        <field name="arch" type="xml">
            <list string="Indicadores Financieros" editable="bottom">
                <field name="name"/>
                <field name="formula"/>
                <field name="threshold_warning"/>
                <field name="threshold_critical"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Acción para gestionar KPIs -->
    <record id="action_account_financial_kpis" model="ir.actions.act_window">
        <field name="name">Indicadores Financieros</field>
        <field name="res_model">account.financial.kpi</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú en Contabilidad → Configuración -->
    <menuitem
        id="menu_account_financial_kpis"
        name="Indicadores Financieros"
        parent="account.menu_finance_configuration"
        action="action_account_financial_kpis"
        sequence="60"/>

</odoo>

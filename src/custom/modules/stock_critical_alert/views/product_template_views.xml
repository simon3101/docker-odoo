<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_stock_min" model="ir.ui.view">
        <field name="name">product.template.form.stock.min</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <!-- stock_min solo se muestra para productos almacenables (is_storable=True)
                     Los servicios y consumibles no tienen stock físico que monitorear -->
                <field name="stock_min"
                       string="Stock Mínimo"
                       invisible="type == 'service' or type == 'combo' "/>
            </xpath>
        </field>
    </record>

    <record id="action_stock_critical_products" model="ir.actions.act_window">
        <field name="name">Productos en Stock Crítico</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('stock_min', '&gt;', 0), ('is_storable', '=', True)]</field>
        <field name="context">{'group_by': 'categ_id'}</field>
    </record>

    <menuitem
        id="menu_stock_critical_alert"
        name="Stock Crítico"
        parent="stock.menu_stock_root"
        action="action_stock_critical_products"
        sequence="99"/>

</odoo>

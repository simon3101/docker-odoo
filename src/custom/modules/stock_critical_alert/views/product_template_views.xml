<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_stock_min" model="ir.ui.view">
        <field name="name">product.template.form.stock.min</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="stock_min"
                       string="Stock Mínimo"
                       invisible="not is_storable"/>
            </xpath>
        </field>
    </record>

    <!-- Client action para el tablero OWL -->
    <record id="action_stock_critical_dashboard" model="ir.actions.client">
        <field name="name">Stock Crítico</field>
        <field name="tag">stock_critical_alert.dashboard</field>
    </record>

    <menuitem
        id="menu_stock_critical_alert"
        name="Stock Crítico"
        parent="stock.menu_stock_root"
        action="action_stock_critical_dashboard"
        sequence="99"/>

</odoo>
